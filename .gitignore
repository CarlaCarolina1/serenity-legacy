# ============================================
# CARLA'S WEBSITE .GITIGNORE
# Created: December 10, 2025
# Based on: Master .gitignore template
# Tech Stack: React (Node.js) + FastAPI (Python)
# ============================================

# ============================================
# PYTHON (Backend)
# ============================================
# Python bytecode - regenerated on import, never commit
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments - dependencies, recreate with requirements.txt
venv/
.venv/
env/
.env/
ENV/
.ENV/

# Python testing & linting
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# Python packaging
*.egg-info/
dist/
build/
*.egg
*.whl

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================
# NODE.JS (Frontend)
# ============================================
# Dependencies - install with npm/yarn/pnpm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
dist-ssr/
build/
.next/
.nuxt/
.vercel/
out/

# TypeScript
*.tsbuildinfo
.tsbuildinfo

# ============================================
# COMPILED FILES (C/C++/Rust)
# ============================================
# Object files - compiled from source, regenerate on build
*.o
*.d
*.obj
*.exe
*.out
*.app

# Rust
target/
Cargo.lock  # Optional - some teams commit this

# CMake
build/
cmake-build-*/

# Static libraries
*.a
*.lib
*.dll
*.dylib
*.so

# ============================================
# IDE / EDITOR FILES
# ============================================
# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# IntelliJ IDEA / PyCharm
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# Eclipse
.project
.classpath
.settings/

# ============================================
# OS FILES
# ============================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ============================================
# LOGS & CACHES
# ============================================
# Log files
*.log
logs/
*.log.*

# Cache directories
*.cache
.cache/
.tmp/
tmp/
temp/
*.tmp

# ============================================
# ENVIRONMENT & SECRETS
# ============================================
# Environment variables - NEVER commit secrets
.env
.env.*
!.env.example
!.env.template

# API keys, tokens, certificates
*.key
*.token
*.pem
*.p12
secrets/
*.secret

# ============================================
# LARGE FILES / MODELS
# ============================================
# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Database files (local development)
*.db
*.sqlite
*.sqlite3
carlas_website.db

# ============================================
# PROJECT-SPECIFIC
# ============================================
# Archive folders
archive/

# ============================================
# END OF .GITIGNORE
# ============================================

